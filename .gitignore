# Obsidian — ignore everything except the shared editor config (README/OBSIDIAN-SETUP.md
# promise pre-tuned line numbers, tab width, and inline-title settings out of the box);
# workspace.json / workspace-mobile.json / plugin caches stay ignored (per-user, not shared)
.obsidian/*
!.obsidian/app.json

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Python virtual environments
.venv/

# lychee link-checker cache
.lycheecache

# Transient release-notes artifact (used as gh release --notes-file source)
RELEASE_NOTES.md

# DP-800 reference clone (used for porting infrastructure/format, not part of this guide)
.reference/
